{
  "name": "samcodes",
  "private": true,
  "scripts": {
    "lint": "eslint './apps/*/app/**/*.{ts,tsx}' --max-warnings 0",
    "typecheck": "pnpm -r tsc --noEmit",
    "test": "pnpm --filter web test",
    "prepare": "husky"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{js,cjs,mjs}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "eslint": "^8.56.0",
    "eslint-config-prettier": "^9.1.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.0.0",
    "prettier": "^3.2.0",
    "typescript": "^5.8.3",
    "vitest": "^3.1.3"
  }
}
